{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/block-protected-files.sh",
        "powershell": ".github/hooks/block-protected-files.ps1",
        "timeoutSec": 5,
        "_comment": "RULE: Block edits to migration files, CI config, and hooks themselves"
      }
    ],

    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/lint-after-edit.sh",
        "powershell": ".github/hooks/lint-after-edit.ps1",
        "timeoutSec": 30,
        "_comment": "RULE: Run linter/formatter on any Java file the agent edits"
      },
      {
        "type": "command",
        "bash": ".github/hooks/audit-log.sh",
        "powershell": ".github/hooks/audit-log.ps1",
        "timeoutSec": 5,
        "_comment": "RULE: Log every tool action for audit trail"
      }
    ]

  }
}
